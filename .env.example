# Environment variables for FHBG Eligibility Bot

# Scraping configuration
SCRAPE_DELAY=2  # Seconds between requests to avoid IP bans
SCRAPE_TIMEOUT=30  # Request timeout in seconds

# Agent configuration
RULE_CACHE_TTL=86400  # Cache TTL in seconds (24 hours)
LOG_LEVEL=INFO  # logging level: DEBUG, INFO, WARNING, ERROR

# Rasa configuration
RASA_MODEL_PATH=models/
RASA_ACTION_SERVER_PORT=5055

# Data paths
NSW_RULES_PATH=src/data/nsw_rules.json
SAMPLE_USERS_PATH=src/data/sample_users.json

# Report generation
REPORT_OUTPUT_DIR=reports/

# Optional: API keys for future integrations
# DOMAIN_API_KEY=your_key_here
# REALESTATE_API_KEY=your_key_here
